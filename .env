# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL Database
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=nedi
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ClickHouse Database
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=yourpassword
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000

# ============================================================================
# DATABASE UI CONFIGURATION
# ============================================================================

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin123

# CH-UI (ClickHouse UI)
VITE_CLICKHOUSE_URL=http://localhost:8123
VITE_CLICKHOUSE_USER=default
VITE_CLICKHOUSE_PASS=yourpassword
VITE_CLICKHOUSE_USE_ADVANCED=false
VITE_CLICKHOUSE_REQUEST_TIMEOUT=30000

# ============================================================================
# DAGSTER CONFIGURATION
# ============================================================================

DAGSTER_POSTGRES_USER=dagster_user
DAGSTER_POSTGRES_PASSWORD=dagster_password
DAGSTER_POSTGRES_DB=dagster_db
DAGSTER_CURRENT_IMAGE=dagster_user_code_image

# ClickHouse HTTP Interface (for setup scripts)
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_HTTP_URL=http://clickhouse:8123

